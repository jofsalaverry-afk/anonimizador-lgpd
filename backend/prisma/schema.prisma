generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Camara {
  id           String      @id @default(cuid())
  nome         String
  cnpj         String      @unique
  email        String      @unique
  senhaHash    String
  ativo        Boolean     @default(true)
  plano        String      @default("basico")
  criadoEm     DateTime    @default(now())
  ultimoAcesso DateTime?
  logoBase64   String?
  cabecalho    String?
  municipio    String?
  documentos   Documento[]
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  senhaHash String
  criadoEm  DateTime @default(now())
}

model Documento {
  id                 String   @id @default(cuid())
  camaraId           String
  camara             Camara   @relation(fields: [camaraId], references: [id])
  tipoDocumento      String
  qtdDadosMascarados Int      @default(0)
  dadosJson          Json?
  criadoEm           DateTime @default(now())
}

// Trilha de auditoria. Captura toda request mutavel (POST/PUT/PATCH/DELETE)
// autenticada. Imutavel: sem update/delete via API.
model LogAuditoria {
  id         String   @id @default(cuid())
  criadoEm   DateTime @default(now())
  userId     String?  // id do Camara ou Admin (null se request sem auth)
  userType   String?  // "camara" | "admin"
  camaraId   String?  // tenant; igual a userId quando userType=camara
  metodo     String   // POST | PUT | PATCH | DELETE
  rota       String   // path da rota (sem query string)
  statusCode Int?     // codigo HTTP final da resposta
  durMs      Int?     // tempo de execucao em milissegundos
  ip         String?  // X-Forwarded-For (Railway proxy)
  userAgent  String?
  body       Json?    // payload sanitizado (sem senha/token/hashes)

  @@index([camaraId, criadoEm])
  @@index([userId, criadoEm])
  @@index([rota, criadoEm])
}