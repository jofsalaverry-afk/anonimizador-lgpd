generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Camara {
  id           String      @id @default(cuid())
  nome         String
  cnpj         String      @unique
  email        String      @unique
  senhaHash    String
  ativo        Boolean     @default(true)
  plano        String      @default("basico")
  criadoEm     DateTime    @default(now())
  ultimoAcesso DateTime?
  logoBase64   String?
  cabecalho    String?
  municipio    String?
  documentos   Documento[]
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  senhaHash String
  criadoEm  DateTime @default(now())
}

model Documento {
  id                 String   @id @default(cuid())
  camaraId           String
  camara             Camara   @relation(fields: [camaraId], references: [id])
  tipoDocumento      String
  qtdDadosMascarados Int      @default(0)
  dadosJson          Json?
  criadoEm           DateTime @default(now())
}