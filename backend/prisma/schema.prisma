generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BaseLegal {
  CONSENTIMENTO
  OBRIGACAO_LEGAL
  EXECUCAO_CONTRATO
  INTERESSE_LEGITIMO
  PROTECAO_VIDA
  TUTELA_SAUDE
  INTERESSE_PUBLICO
  EXERCICIO_DIREITOS
}

enum TipoDireito {
  ACESSO
  CORRECAO
  ELIMINACAO
  PORTABILIDADE
  OPOSICAO
  REVOGACAO
  INFORMACAO
  PETICAO
}

enum StatusDSAR {
  RECEBIDA
  EM_ANALISE
  RESPONDIDA
  ENCERRADA
  CANCELADA
}

enum TipoDocRepo {
  POLITICA
  TERMO
  ADITIVO
  CONTRATO
  MODELO
  OUTRO
}

enum StatusDocRepo {
  RASCUNHO
  APROVADO
  PUBLICADO
}

enum TipoIncidente {
  VAZAMENTO
  ACESSO_INDEVIDO
  PERDA
  ALTERACAO
  OUTRO
}

enum StatusIncidente {
  ABERTO
  EM_INVESTIGACAO
  RESOLVIDO
  ENCERRADO
}

enum Criticidade {
  ALTA
  MEDIA
  BAIXA
}

enum EvidenciaRequerida {
  DOCUMENTO
  CAPTURA
  AUTO_DECLARACAO
  LINK_SISTEMA
}

enum StatusResposta {
  CONFORME
  PARCIAL
  NAO_CONFORME
  NAO_APLICAVEL
}

enum TipoAlerta {
  DSAR_PRAZO
  CHECKLIST_REVISAO
  INCIDENTE_ABERTO
  ROPA_DESATUALIZADO
}

enum Perfil {
  ENCARREGADO_LGPD
  GESTOR
  OPERADOR
  AUDITOR
  TREINANDO
}

model Organizacao {
  id           String      @id @default(cuid())
  nome         String
  cnpj         String      @unique
  ativo        Boolean     @default(true)
  plano        String      @default("basico")
  criadoEm     DateTime    @default(now())
  logoBase64   String?
  cabecalho    String?
  municipio    String?
  modulosAtivos  String[]   @default(["anonimizador"])
  usuarios       Usuario[]
  documentos     Documento[]
  tratamentos    Tratamento[]
  solicitacoes   SolicitacaoTitular[]
  modelosDSAR    ModeloRespostaDSAR[]
  docsRepo       DocumentoRepositorio[]
  incidentes     Incidente[]
  respostasChecklist RespostaChecklist[]
  alertas        AlertaConformidade[]
}

model Usuario {
  id             String    @id @default(cuid())
  email          String    @unique
  senhaHash      String
  nome           String
  perfil         Perfil    @default(OPERADOR)
  ativo          Boolean   @default(true)
  criadoEm       DateTime  @default(now())
  ultimoAcesso   DateTime?
  organizacaoId  String
  organizacao    Organizacao @relation(fields: [organizacaoId], references: [id])
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  senhaHash String
  criadoEm  DateTime @default(now())
}

model Documento {
  id                 String      @id @default(cuid())
  organizacaoId      String
  organizacao        Organizacao @relation(fields: [organizacaoId], references: [id])
  usuarioId          String?
  tipoDocumento      String
  qtdDadosMascarados Int         @default(0)
  dadosJson          Json?
  criadoEm           DateTime    @default(now())
}

// Trilha de auditoria. Captura toda request mutavel (POST/PUT/PATCH/DELETE)
// autenticada. Imutavel: sem update/delete via API.
model LogAuditoria {
  id         String   @id @default(cuid())
  criadoEm   DateTime @default(now())
  userId     String?
  userType   String?  // "usuario" | "admin"
  camaraId   String?  // legado; equivale a organizacaoId
  metodo     String
  rota       String
  statusCode Int?
  durMs      Int?
  ip         String?
  userAgent  String?
  body       Json?

  @@index([camaraId, criadoEm])
  @@index([userId, criadoEm])
  @@index([rota, criadoEm])
}

// ============ ROPA (Registro de Operacoes de Tratamento) ============

model Tratamento {
  id                  String      @id @default(cuid())
  organizacaoId       String
  organizacao         Organizacao @relation(fields: [organizacaoId], references: [id])
  nome                String
  finalidade          String
  baseLegal           BaseLegal
  categoriasDados     String[]
  categoriasTitulares String[]
  retencaoDias        Int?
  formaDescarte       String?
  responsavelId       String?
  medidasSeguranca    String?
  ativo               Boolean     @default(true)
  criadoEm            DateTime    @default(now())
  atualizadoEm        DateTime    @updatedAt

  compartilhamentos   CompartilhamentoTratamento[]
  historico           TratamentoHistorico[]

  @@index([organizacaoId, ativo])
}

model CompartilhamentoTratamento {
  id                          String     @id @default(cuid())
  tratamentoId                String
  tratamento                  Tratamento @relation(fields: [tratamentoId], references: [id], onDelete: Cascade)
  terceiroNome                String
  terceiroCNPJ                String?
  finalidadeCompartilhamento  String
  paisDestino                 String     @default("Brasil")
  baseLegalTransferencia      String?

  @@index([tratamentoId])
}

model TratamentoHistorico {
  id            String     @id @default(cuid())
  tratamentoId  String
  tratamento    Tratamento @relation(fields: [tratamentoId], references: [id], onDelete: Cascade)
  snapshot      Json
  alteradoPor   String
  criadoEm      DateTime   @default(now())

  @@index([tratamentoId, criadoEm])
}

// ============ DSAR (Direitos do Titular) ============

model SolicitacaoTitular {
  id               String      @id @default(cuid())
  organizacaoId    String
  organizacao      Organizacao @relation(fields: [organizacaoId], references: [id])
  protocolo        String      @unique
  titularNome      String
  titularEmail     String
  titularCpf       String?
  tipoDireito      TipoDireito
  descricao        String
  status           StatusDSAR  @default(RECEBIDA)
  dataRecebimento  DateTime    @default(now())
  dataLimite       DateTime
  dataResposta     DateTime?
  respostaTexto    String?
  responsavelId    String?
  criadoEm         DateTime    @default(now())
  atualizadoEm     DateTime    @updatedAt

  evidencias       EvidenciaDSAR[]

  @@index([organizacaoId, status])
  @@index([protocolo])
  @@index([organizacaoId, dataLimite])
}

model EvidenciaDSAR {
  id             String             @id @default(cuid())
  solicitacaoId  String
  solicitacao    SolicitacaoTitular @relation(fields: [solicitacaoId], references: [id], onDelete: Cascade)
  tipo           String
  descricao      String
  arquivoUrl     String?
  hashSha256     String?
  autorId        String
  criadoEm       DateTime           @default(now())

  @@index([solicitacaoId])
}

model ModeloRespostaDSAR {
  id             String      @id @default(cuid())
  organizacaoId  String
  organizacao    Organizacao @relation(fields: [organizacaoId], references: [id])
  tipoDireito    TipoDireito
  titulo         String
  conteudo       String
  padrao         Boolean     @default(false)
  criadoEm       DateTime    @default(now())

  @@index([organizacaoId, tipoDireito])
}

// ============ Repositorio de Documentos e Incidentes ============

model DocumentoRepositorio {
  id             String        @id @default(cuid())
  organizacaoId  String
  organizacao    Organizacao   @relation(fields: [organizacaoId], references: [id])
  tipo           TipoDocRepo
  titulo         String
  conteudoMd     String        @default("")
  versao         Int           @default(1)
  status         StatusDocRepo @default(RASCUNHO)
  autorId        String?
  tags           String[]
  criadoEm       DateTime      @default(now())
  atualizadoEm   DateTime      @updatedAt

  @@index([organizacaoId, tipo])
  @@index([organizacaoId, status])
}

model Incidente {
  id              String          @id @default(cuid())
  organizacaoId   String
  organizacao     Organizacao     @relation(fields: [organizacaoId], references: [id])
  titulo          String
  dataOcorrencia  DateTime
  dataDescoberta  DateTime        @default(now())
  tipoIncidente   TipoIncidente
  dadosAfetados   String[]
  qtdTitulares    Int             @default(0)
  notificadoANPD  Boolean         @default(false)
  status          StatusIncidente @default(ABERTO)
  descricao       String
  planoAcao       String?
  autorId         String?
  criadoEm        DateTime        @default(now())
  atualizadoEm    DateTime        @updatedAt

  @@index([organizacaoId, status])
}

// ============ Checklist de Conformidade ============

model ItemChecklist {
  id                  String             @id @default(cuid())
  codigo              String             @unique
  categoria           String
  titulo              String
  descricao           String
  fundamentoLegal     String
  obrigatorio         Boolean            @default(true)
  criticidade         Criticidade
  evidenciaRequerida  EvidenciaRequerida
  respostas           RespostaChecklist[]
}

model RespostaChecklist {
  id              String         @id @default(cuid())
  organizacaoId   String
  organizacao     Organizacao    @relation(fields: [organizacaoId], references: [id])
  itemId          String
  item            ItemChecklist  @relation(fields: [itemId], references: [id])
  status          StatusResposta
  observacao      String?
  evidenciaUrl    String?
  evidenciaHash   String?
  validadoPor     String?
  proximaRevisao  DateTime?
  criadoEm        DateTime       @default(now())
  atualizadoEm    DateTime       @updatedAt

  @@unique([organizacaoId, itemId])
  @@index([organizacaoId])
}

model AlertaConformidade {
  id             String      @id @default(cuid())
  organizacaoId  String
  organizacao    Organizacao @relation(fields: [organizacaoId], references: [id])
  tipo           TipoAlerta
  mensagem       String
  criticidade    Criticidade
  lido           Boolean     @default(false)
  referenciaId   String?
  criadoEm       DateTime    @default(now())

  @@index([organizacaoId, lido])
  @@index([organizacaoId, criadoEm])
}

// ============ Treinamento ============
// Override de youtubeId/titulo de modulos das trilhas hardcoded.
// Permite admin curar conteudo sem alterar codigo. Global — afeta
// todas as organizacoes (trilhas sao compartilhadas).
model TrilhaOverride {
  id         String   @id @default(cuid())
  trilhaId   String
  moduloId   String
  youtubeId  String
  titulo     String?
  atualizadoEm DateTime @updatedAt

  @@unique([trilhaId, moduloId])
}
