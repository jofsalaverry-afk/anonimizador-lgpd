generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Perfil {
  ENCARREGADO_LGPD
  GESTOR
  OPERADOR
  AUDITOR
  TREINANDO
}

model Organizacao {
  id           String      @id @default(cuid())
  nome         String
  cnpj         String      @unique
  ativo        Boolean     @default(true)
  plano        String      @default("basico")
  criadoEm     DateTime    @default(now())
  logoBase64   String?
  cabecalho    String?
  municipio    String?
  modulosAtivos String[]   @default(["anonimizador"])
  usuarios     Usuario[]
  documentos   Documento[]
}

model Usuario {
  id             String    @id @default(cuid())
  email          String    @unique
  senhaHash      String
  nome           String
  perfil         Perfil    @default(OPERADOR)
  ativo          Boolean   @default(true)
  criadoEm       DateTime  @default(now())
  ultimoAcesso   DateTime?
  organizacaoId  String
  organizacao    Organizacao @relation(fields: [organizacaoId], references: [id])
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  senhaHash String
  criadoEm  DateTime @default(now())
}

model Documento {
  id                 String      @id @default(cuid())
  organizacaoId      String
  organizacao        Organizacao @relation(fields: [organizacaoId], references: [id])
  usuarioId          String?
  tipoDocumento      String
  qtdDadosMascarados Int         @default(0)
  dadosJson          Json?
  criadoEm           DateTime    @default(now())
}

// Trilha de auditoria. Captura toda request mutavel (POST/PUT/PATCH/DELETE)
// autenticada. Imutavel: sem update/delete via API.
model LogAuditoria {
  id         String   @id @default(cuid())
  criadoEm   DateTime @default(now())
  userId     String?
  userType   String?  // "usuario" | "admin"
  camaraId   String?  // legado; equivale a organizacaoId
  metodo     String
  rota       String
  statusCode Int?
  durMs      Int?
  ip         String?
  userAgent  String?
  body       Json?

  @@index([camaraId, criadoEm])
  @@index([userId, criadoEm])
  @@index([rota, criadoEm])
}
